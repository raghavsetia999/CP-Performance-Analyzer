NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/cp-performance-analyzer
CLIENT_ORIGIN=http://localhost:5173
JWT_SECRET=replace-with-a-random-secret-that-is-at-least-32-characters
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
CODEFORCES_API_BASE_URL=https://codeforces.com/api
CODEFORCES_TIMEOUT_MS=10000
CODEFORCES_CACHE_TTL_MS=300000
CODEFORCES_PROBLEMSET_CACHE_TTL_MS=21600000
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com
OPENAI_API_KEY=
AI_MODEL=gemini-3.5-flash
AI_FALLBACK_MODEL=gemini-3.1-flash-lite
AI_TIMEOUT_MS=15000
AI_MAX_OUTPUT_TOKENS=2048
AI_RATE_LIMIT_WINDOW_MS=900000
AI_RATE_LIMIT_MAX=20
